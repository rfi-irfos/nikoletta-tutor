# GitHub repo that holds the site content + images
VITE_GH_OWNER=rfi-irfos
VITE_GH_REPO=nikoletta-tutor
# Fine-grained PAT: Contents Read+Write on the above repo only
VITE_GH_TOKEN=ghp_...

# Path inside the repo to content.json (relative to repo root)
VITE_GH_CONTENT_PATH=public/content.json
VITE_GH_UPLOADS_DIR=public/uploads

# SHA-256 hash of the admin password — generate with: echo -n "yourpassword" | sha256sum
# Current hash is for password "niki-coach-2026"
VITE_ADMIN_HASH=8227436fc2f7d2610918a76096f984ec1445cc04b1691e44d479df0c72c43984

# GitHub PAT is NOT stored here — Niki enters it once at first login in the browser
# Fine-grained PAT: Contents Read+Write on the above repo only

# Web3Forms access key — get free at web3forms.com
VITE_WEB3FORMS_KEY=...

# Vite base path — '/' for custom domain, '/repo-name/' for github.io URL
VITE_BASE_URL=/nikoletta-tutor/
